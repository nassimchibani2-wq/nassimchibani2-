   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
const TRUSTED_SOURCES = [
  /* جزائرية */ 'aps','ennahar','echorouk','elkhabar','elmoudjahid','tsa','liberte',
  /* دولية */   'reuters','apnews','afp','bbc','bloomberg','associated press',
  /* عربية */   'aljazeera','france24','dw','guardian','nytimes','washingtonpost','cnn',
];

const OFFICIAL_SOURCES = ['aps','entv','radioalgerie','elmoudjahid'];

/**
 * تحليل مصداقية خبر — تعيد score (0–100) + label + status
 * @param {Object} a — كائن الخبر من NewsAPI
 */
function analyzeCredibility(a) {
  let score = 0;
  if (a.urlToImage && !a.urlToImage.includes('placeholder')) score += 30;
  if (a.description && a.description.length > 80)            score += 25;
  const src = ((a.source?.name || '') + (a.source?.id || '')).toLowerCase();
  if (TRUSTED_SOURCES.some((s) => src.includes(s)))          score += 20;
  if (a.content && !a.content.includes('[+'))                score += 15;
  if (a.publishedAt && (Date.now() - new Date(a.publishedAt)) / 36e5 < 72) score += 10;

  const t      = I18N[state.lang];
  const status = score >= 60 ? 'verified' : 'unverified';
  const label  = score >= 60 ? t.verified : t.unverified;
  return { score, label, status };
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   5. API — جلب الأخبار
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
const cache = {};

/** تنظيف الصورة */
function optimizeImg(url) {
  if (!url) return CONFIG.FALLBACK_IMG;
  if (url.includes('unsplash.com')) return url.split('?')[0] + '?w=400&q=70&auto=format';
  if (url.match(/\.(jpg|jpeg)/i))   return url.replace(/-\d{3,4}x\d{3,4}(?=\.(jpg|jpeg))/i, '-400x300');
  return url;
}

/** تنظيف المقالات */
function clean(articles) {
  return (articles || []).filter((a) => a.title && a.title !== '[Removed]');
}

/**
 * جلب الأخبار باستخدام everything?q=
 *
 * هذه هي الدالة الوحيدة لجلب الأخبار الآن —
 * تعمل مع أي كلمة بحث لأي دولة أو موضوع.
 *
 * @param {string} query — نص البحث
 * @returns {Promise<Array>}
 */
async function fetchByQuery(query) {
  /* فحص الـ Cache */
  const key    = query.toLowerCase().trim();
  const cached = cache[key];
  if (cached && Date.now() - cached.ts < CONFIG.CACHE_DURATION) {
    console.log(`[Cache ✓] "${key}" — ${cached.data.length} نتيجة`);
    return cached.data;
  }

  const params = new URLSearchParams({
    q:        query,
    sortBy:   'publishedAt',
    pageSize: CONFIG.PAGE_SIZE,
    apiKey:   CONFIG.API_KEY,
  });

  const url = `${CONFIG.BASE_URL}/everything?${params}`;
  console.log(`[API] everything?q=${query}`);

  const res  = await fetch(url);

  /*
    ⚠️ لا نرمي خطأ مباشرةً حتى نعطي رسائل واضحة
    نفحص الكود ونرمي رسالة مخصصة
  */
  if (!res.ok) throw new Error(String(res.status));

  const data = await res.json();
  if (data.status !== 'ok') throw new Error(data.message || 'API error');

  const articles = clean(data.articles);
  cache[key] = { data: articles, ts: Date.now() };
  return articles;
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   6. TRANSLATE — ترجمة بسيطة مجانية
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   نستخدم MyMemory API — مجاني بدون تسجيل
   حد مجاني: 5000 حرف/يوم
   الرابط: https://mymemory.translated.net/api/get
*/

/*
  خريطة رموز اللغات لـ MyMemory:
  ar = عربي | en = إنجليزي | fr = فرنسي
*/
const LANG_CODES = { ar: 'ar', en: 'en', fr: 'fr' };

/**
 * يترجم نصاً إلى اللغة المختارة
 * @param {string} text     — النص الأصلي
 * @param {string} targetLang — رمز اللغة الهدف (ar/en/fr)
 * @returns {Promise<string>} النص المترجم
 */
async function translateText(text, targetLang) {
  if (!text || text.trim() === '') return '';

  /*
    MyMemory يحتاج أن نحدد لغة المصدر.
    معظم أخبار NewsAPI بالإنجليزية → المصدر دائماً 'en'
    إلا إذا كانت اللغة المختارة 'en' → لا حاجة للترجمة
  */
  if (targetLang === 'en') return text; /* الأخبار أصلاً بالإنجليزية */

  const sourceLang = 'en';
  const langPair   = `${sourceLang}|${LANG_CODES[targetLang]}`;

  const params = new URLSearchParams({
    q:        text.slice(0, 500), /* MyMemory: حد 500 حرف للطلب المجاني */
    langpair: langPair,
  });

  const res  = await fetch(`https://api.mymemory.translated.net/get?${params}`);
  const data = await res.json();

  /*
    البنية: data.responseData.translatedText
    200 = نجاح | 403 = تجاوز الحد اليومي
  */
  if (data.responseStatus === 200) {
    return data.responseData.translatedText || text;
  }

  throw new Error(`Translation failed: ${data.responseStatus}`);
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   7. STATE — الحالة العامة
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */
const state = {
  lang:          'ar',        /* اللغة الحالية */
  currentQuery:  '',          /* آخر نص بحث */
  currentFilter: 'all',       /* all / verified / unverified */
  articles:      [],          /* الأخبار الحالية */
