/** رسم الوسوم السريعة */
function renderQuickTags() {
  const tags = QUICK_TAGS[state.lang] || QUICK_TAGS.ar;
  DOM.quickTags.innerHTML = tags.map((tag) => `
    <button
      class="quick-tag ${tag.query === state.activeTag ? 'active' : ''}"
      data-query="${tag.query}"
      role="listitem"
    >${tag.label}</button>
  `).join('');
}

/** تنسيق التاريخ */
function formatDate(str) {
  if (!str) return '';
  const t       = I18N[state.lang];
  const diff    = Date.now() - new Date(str);
  const mins    = Math.floor(diff / 60000);
  const hrs     = Math.floor(mins / 60);
  const days    = Math.floor(hrs / 24);
  if (mins < 60)  return t.agoMin.replace('{n}', mins);
  if (hrs  < 24)  return t.agoHr.replace('{n}', hrs);
  if (days < 7)   return t.agoDays.replace('{n}', days);
  return new Date(str).toLocaleDateString(
    state.lang === 'ar' ? 'ar-DZ' : state.lang === 'fr' ? 'fr-FR' : 'en-GB',
    { day:'numeric', month:'long', year:'numeric' }
  );
}

/** بناء HTML بطاقة خبر */
function buildCard(article, index) {
  const t      = I18N[state.lang];
  const cred   = analyzeCredibility(article);
  const imgSrc = optimizeImg(article.urlToImage);
  const date   = formatDate(article.publishedAt);
  const source = article.source?.name || t.sourceUnknown;
  const src    = source.toLowerCase();
  const isOff  = OFFICIAL_SOURCES.some((s) => src.includes(s));
  const offBadge = isOff
    ? `<span class="card-badge official" style="top:38px">${t.official}</span>`
    : '';

  return `
    <article class="news-card" data-index="${index}" data-status="${cred.status}"
      role="article" tabindex="0" aria-label="${article.title}">
      <div class="card-img-wrap">
        <img class="card-img" src="${imgSrc}" alt="${article.title}"
          loading="lazy" decoding="async" width="400" height="170"
          onerror="this.src='${CONFIG.FALLBACK_IMG}'" />
        <span class="card-badge ${cred.status}">${cred.label}</span>
        ${offBadge}
      </div>
      <div class="card-body">
        <div class="card-meta">
          <span class="card-query">🔍 ${state.currentQuery}</span>
          <span class="card-date">${date}</span>
        </div>
        <h2 class="card-title">${article.title}</h2>
        <div class="card-footer">
          <span class="card-source">${source}</span>
          <span class="card-arrow">${state.lang === 'ar' ? '←' : '→'}</span>
        </div>
      </div>
    </article>
  `;
}

/** عرض الأخبار مع تطبيق الفلتر */
function renderNews() {
  const t        = I18N[state.lang];
  const filtered = state.currentFilter === 'all'
    ? state.articles
    : state.articles.filter((a) => analyzeCredibility(a).status === state.currentFilter);

  if (filtered.length === 0) {
    DOM.newsGrid.innerHTML = `
      <div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-muted)">
        ${t.noFilter}
      </div>`;
    return;
  }

  DOM.newsGrid.innerHTML = filtered.map((a, i) => buildCard(a, i)).join('');
}

/** تبديل حالة الواجهة */
function showState(s) {
  DOM.welcomeState.classList.toggle('hidden',  s !== 'welcome');
  DOM.loadingState.classList.toggle('hidden',  s !== 'loading');
  DOM.errorState.classList.toggle('hidden',    s !== 'error');
  DOM.newsGrid.classList.toggle('hidden',      s !== 'results');
}

/* ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
   11. SEARCH — البحث الرئيسي
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

/**
 * دالة البحث الرئيسية
 * @param {string} query — نص البحث
 */
async function doSearch(query) {
  const t = I18N[state.lang];
  query   = query.trim();
  if (!query) { showState('welcome'); return; }

  state.currentQuery = query;
  state.articles     = [];
  DOM.newsGrid.innerHTML = '';
  DOM.statusText.textContent = t.loading;
  showState('loading');

  try {
    const articles     = await fetchByQuery(query);
    state.articles     = articles;
    showState('results');
    renderNews();
    DOM.statusText.textContent = articles.length > 0
      ? t.newsCount.replace('{n}', articles.length)
      : t.noResults;
  } catch (err) {
    console.error('[doSearch]', err);
    let msg = t.errGeneric;
    if (!navigator.onLine)           msg = t.errOffline;
    else if (err.message === '401')  msg = t.errKey;
    else if (err.message === '426')  msg = t.errLocalhost;
    else if (err.message === '429')  msg = t.errRate;
    DOM.errorMessage.textContent = msg;
    showState('error');
    DOM.statusText.textContent = '⚠️';
  }
}

