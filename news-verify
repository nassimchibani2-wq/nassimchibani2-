   9. LANGUAGE — تطبيق اللغة
   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ */

/**
 * يطبّق اللغة على كامل الصفحة
 * @param {string} lang — 'ar' | 'en' | 'fr'
 */
function applyLanguage(lang) {
  state.lang = lang;
  const t    = I18N[lang];

  /* 1. اتجاه الصفحة */
  const isRTL = lang === 'ar';
  document.documentElement.lang     = lang;
  document.documentElement.dir      = isRTL ? 'rtl' : 'ltr';
  document.body.setAttribute('dir', isRTL ? 'rtl' : 'ltr');
  document.body.setAttribute('data-lang', lang);

  /* 2. ترجمة كل العناصر data-i18n */
  document.querySelectorAll('[data-i18n]').forEach((el) => {
    const key = el.dataset.i18n;
    if (t[key] !== undefined) el.textContent = t[key];
  });

  /* 3. placeholder خانة البحث */
  DOM.searchInput.placeholder = t.searchPlaceholder;

  /* 4. تحديث زر اللغة */
  DOM.currentLangFlag.textContent = t.langFlag;
  DOM.currentLangName.textContent = t.langName;

  /* 5. تحديث حالة أزرار اللغة */
  document.querySelectorAll('.lang-option').forEach((btn) => {
    btn.classList.toggle('active', btn.dataset.lang === lang);
  });

  /* 6. إعادة رسم الوسوم السريعة */
  renderQuickTags();

  /* 7. إعادة رسم الأخبار الموجودة بالنصوص الجديدة */
  if (state.articles.length > 0) renderNews();
}

